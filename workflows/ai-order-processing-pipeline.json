    {
      "parameters": {
        "sendTo": "operations@example.com",
        "subject": "={{ $json.output[0].content[0].text.email_subject }}",
        "message": "=<div style=\"font-family: Arial, Helvetica, sans-serif; background-color: #f6f8fa; padding: 24px; color: #222;\">\n  <div style=\"max-width: 640px; background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 10px; overflow: hidden;\">\n\n    <div style=\"background-color: #111827; color: #ffffff; padding: 20px 24px;\">\n      <h2 style=\"margin: 0; font-size: 22px;\">📦 New Customer Order</h2>\n      <p style=\"margin: 6px 0 0; color: #d1d5db; font-size: 14px;\">Order Ready for Review</p>\n    </div>\n\n    <div style=\"padding: 24px;\">\n      <div style=\"background:#eff6ff;\n        border:1px solid #bfdbfe;\n        color:#1e3a8a;\n        padding:14px 16px;\n        border-radius:8px;\n        margin-bottom:24px;\n        font-size:14px;\"> ℹ️ A new customer order has been received and is awaiting operations review.\n    </div>\n\n      <h3 style=\"font-size: 16px; margin: 24px 0 12px;\">📋 Order Details</h3>\n\n      <table style=\"border-collapse: collapse; width: 100%; font-size: 14px;\">\n        <tr>\n          <td style=\"padding: 10px 12px; border: 1px solid #e5e7eb; background-color: #f9fafb; font-weight: bold; width: 35%;\">Order #</td>\n          <td style=\"padding: 10px 12px; border: 1px solid #e5e7eb;\">{{ $('Mark as Processing').item.json.fields['Order Number'] }}</td>\n        </tr>\n        <tr>\n          <td style=\"padding: 10px 12px; border: 1px solid #e5e7eb; background-color: #f9fafb; font-weight: bold;\">Customer</td>\n          <td style=\"padding: 10px 12px; border: 1px solid #e5e7eb;\">{{ $('Mark as Processing').item.json.fields.Customer }}</td>\n        </tr>\n        <tr>\n          <td style=\"padding: 10px 12px; border: 1px solid #e5e7eb; background-color: #f9fafb; font-weight: bold;\">Product</td>\n          <td style=\"padding: 10px 12px; border: 1px solid #e5e7eb;\">{{ $('Mark as Processing').item.json.fields.Product }}</td>\n        </tr>\n        <tr>\n          <td style=\"padding: 10px 12px; border: 1px solid #e5e7eb; background-color: #f9fafb; font-weight: bold;\">Quantity</td>\n          <td style=\"padding: 10px 12px; border: 1px solid #e5e7eb;\">{{ $('Mark as Processing').item.json.fields.Quantity }}</td>\n        </tr>\n        <tr>\n          <td style=\"padding: 10px 12px; border: 1px solid #e5e7eb; background-color: #f9fafb; font-weight: bold;\">Price</td>\n          <td style=\"padding: 10px 12px; border: 1px solid #e5e7eb;\">${{ Number($('Mark as Processing').item.json.fields.Price).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) }}</td>\n        </tr>\n        <tr>\n          <td style=\"padding: 10px 12px; border: 1px solid #e5e7eb; background-color: #f9fafb; font-weight: bold;\">Order Date</td>\n          <td style=\"padding: 10px 12px; border: 1px solid #e5e7eb;\">{{ DateTime.fromISO($('Mark as Processing').item.json.fields.Date).toFormat('MMMM d, yyyy') }}</td>\n        </tr>\n        <tr>\n          <td style=\"padding: 10px 12px; border: 1px solid #e5e7eb; background-color: #f9fafb; font-weight: bold;\">Status</td>\n          <td style=\"padding: 10px 12px; border: 1px solid #e5e7eb;\">\n            <span style=\"display: inline-block; background-color: #fef3c7; color: #92400e; padding: 3px 8px; border-radius: 999px; font-size: 12px; font-weight: bold;\">\n              {{ $('Mark as Processing').item.json.fields.Status }}\n            </span>\n          </td>\n        </tr>\n      </table>\n\n      <h3 style=\"font-size: 16px; margin: 24px 0 12px;\"> 🤖 AI Fulfillment Summary </h3>\n\n      <div style=\"background-color: #f9fafb; border-left: 4px solid #2563eb; padding: 14px 16px; font-size: 14px;\">\n        {{ $json.output[0].content[0].text.order_summary }}\n      </div>\n\n      <p style=\"margin-top: 24px;\">Please review this order and begin processing.</p>\n\n      <hr style=\"margin:32px 0 20px;border:none;border-top:1px solid #e5e7eb;\">\n\n        <p style=\"margin:0;font-size:14px;font-weight:bold;color:#374151;\">AI Order Processing Pipeline</p>\n        <p style=\"margin:4px 0 0;font-size:12px;color:#6b7280;\">Automated Operations Notification</p>\n    </div>\n\n  </div>\n</div>",
