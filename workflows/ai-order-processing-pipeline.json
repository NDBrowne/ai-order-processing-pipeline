    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "gpt-4o-mini",
          "mode": "list",
          "cachedResultName": "GPT-4O-MINI"
        },
        "responses": {
          "values": [
            {
              "content": "=You are an AI assistant helping an internal operations team process customer orders.\n\nYour task is to generate a short, professional order summary for the Operations Team.\n\nUse only the information provided. Do not invent missing details. Do not change order numbers, prices, quantities, dates, customer names, or product names.\n\nOrder Information:\nOrder #: {{ $json.fields['Order Number'] }}\nCustomer: {{ $json.fields.Customer }}\nProduct: {{ $json.fields.Product }}\nQuantity: {{ $json.fields.Quantity }}\nPrice: {{ $json.fields.Price }}\nOrder Date: {{ $json.fields.Date }}\nStatus: {{ $json.fields.Status }}\n\nReturn valid JSON only with the following fields:\n\nemail_subject\norder_summary\n\nRules:\n- email_subject must be: New Customer Order Summary - Order # followed by the order number.\n- order_summary should be a single concise sentence (20–25 words maximum).\n- Focus on the next actions required by the Operations Team.\n- Do not repeat the customer, product, quantity, price, date, or status.\n- Do not describe work as already being completed.\n- Use action-oriented language beginning with \"Please...\"\n- Do not include greetings or sign-offs.\n- Return valid JSON only.\n\nExample:\n\n{\n  \"email_subject\": \"New Customer Order Summary - Order #123\",\n  \"order_summary\": \"Please verify inventory, initiate assembly, and update the order status as fulfillment progresses.\"\n}"
            }
          ]
        },
        "builtInTools": {},
        "options": {
          "textFormat": {
            "textOptions": {
              "type": "json_object"
            }
          }
        }
